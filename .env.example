# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://dfdocnhhxrnvblbwwium.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # server only — get from dashboard

# Anthropic (Phase 2+)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — required for the lesson audio pipeline (/yaml-generate).
# Without it, the YAML still ships but every language is reported as
# "audio: api_key_missing". See lib/audio/voices.ts for the per-language
# voice + model selection.
ELEVENLABS_API_KEY=sk_...

# App
#   - In Vercel production this is https://myaisetu.com (used by
#     canonical link, og:url, and twitter card metadata in layout.tsx).
#   - Local dev defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AIS

# Sentry (optional — SDK no-ops without a DSN)
#   - Create a Next.js project at sentry.io and paste its DSN below.
#   - SENTRY_AUTH_TOKEN is needed only for sourcemap upload at build
#     time; the Vercel Sentry integration injects it automatically.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Wiki (/wiki) — admin allow-list.
#   Comma-separated emails. Only addresses in this list can read /wiki.
#   Empty / missing = no one. Edits to wiki pages happen via PR (commits
#   to content/wiki/*.mdx), not through an in-browser editor.
WIKI_ADMINS=

# Cashfree Payment Gateway — powers /join → /payment-success funnel.
#   - APP_ID + SECRET_KEY from Cashfree dashboard → Developers → API Keys
#   - WEBHOOK_SECRET from Cashfree dashboard → Developers → Webhooks
#     (configure POST https://myaisetu.com/api/webhooks/cashfree)
#   - ENV is 'SANDBOX' (default) or 'PRODUCTION'
#   Until set, /join shows an "email us, payments aren't live" notice
#   instead of crashing.
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
#   - CASHFREE_WEBHOOK_SECRET: dashboard → Developers → Webhooks. If
#     your account signs webhooks with the API client secret instead
#     (some Cashfree accounts do), leave this blank — we fall back
#     to CASHFREE_SECRET_KEY automatically.
CASHFREE_WEBHOOK_SECRET=
CASHFREE_ENV=SANDBOX

# Meta Pixel + Conversions API — powers ad-conversion tracking for
# the /join → /students-plan → Cashfree → /payment-success funnel.
#   - NEXT_PUBLIC_META_PIXEL_ID: Meta Business Manager → Events
#     Manager → your pixel → Settings. Public; ships to the browser
#     so the Pixel SDK can load.
#   - META_CAPI_ACCESS_TOKEN: Events Manager → Settings →
#     Conversions API → Generate access token. Server-only secret;
#     never exposed to the browser.
#   - META_TEST_EVENT_CODE: Events Manager → Test Events → "Test
#     server events" code (TESTxxxx). Set in dev/staging so events
#     show in the Test Events tab and DON'T pollute production
#     attribution. Leave blank in production.
#   Until both NEXT_PUBLIC_META_PIXEL_ID and META_CAPI_ACCESS_TOKEN
#   are set, all tracking calls are silent no-ops.
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
