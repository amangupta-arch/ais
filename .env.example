# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://dfdocnhhxrnvblbwwium.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # server only — get from dashboard

# Anthropic (Phase 2+)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — required for the lesson audio pipeline (/yaml-generate).
# Without it, the YAML still ships but every language is reported as
# "audio: api_key_missing". See lib/audio/voices.ts for the per-language
# voice + model selection.
ELEVENLABS_API_KEY=sk_...

# App
#   - In Vercel production this is https://myaisetu.com (used by
#     canonical link, og:url, and twitter card metadata in layout.tsx).
#   - Local dev defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AIS

# Sentry (optional — SDK no-ops without a DSN)
#   - Create a Next.js project at sentry.io and paste its DSN below.
#   - SENTRY_AUTH_TOKEN is needed only for sourcemap upload at build
#     time; the Vercel Sentry integration injects it automatically.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
